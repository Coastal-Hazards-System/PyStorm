# Data — large files, not version-controlled
# (anchored with **/ so the rule applies to module-nested data/ trees too)
**/data/raw/
**/data/processed/

# Python
__pycache__/
*.pyc
*.pyo
.eggs/
*.egg-info/
dist/
build/

# C++ build artifacts
*.pyd
*.so
*.dylib
_build/

# Editors / IDE / OS
.DS_Store
Thumbs.db
.venv/
*.env
.idea/
.claude/
