# Data — large files, not version-controlled
# (anchored with **/ so the rule applies to module-nested data/ trees too)
**/data/inputs/
**/data/outputs/

# Archive — local-only stash of legacy data + superseded docs + reports (not on GitHub)
archive/

# Python
__pycache__/
*.pyc
*.pyo
.eggs/
*.egg-info/
dist/
build/

# C++ build artifacts
*.pyd
*.so
*.dylib
_build/

# Editors / IDE / OS
.DS_Store
Thumbs.db
.venv/
*.env
.idea/
.claude/

# Office lock/temp files (e.g. an open slide-deck .pptx in PowerPoint)
~$*

# Companion whitepapers and slide decks (local documents, not versioned in this repo).
# Global by name pattern so every module's, and any future module's, are covered.
*_Whitepaper.md
*_Slides.md
*_Slides*.pptx
*_Slides*.pdf
*_Slides*.html
